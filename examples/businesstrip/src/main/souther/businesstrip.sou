// 出張申請モデルの一断面。ドメインは data＋invariant＋behavior だけ。
// decoder/encoder は書かない（導出される。JSON キー＝フィールド名、`data X = Y` は裸の newtype）。
// カスタムのキー名・正規化・判別子が要るなら、それは境界（Java/Raoh）の仕事。
//
// コンパイル: java -cp souther-compiler/target/classes \
//              net.unit8.souther.compiler.Main compile examples/businesstrip/src/main/souther/businesstrip.sou -d /tmp/out
module example.businesstrip
import String ( length )

data 従業員ID = String
    invariant length(value) > 0

data 金額 = Int
    invariant value >= 0

data 出張申請共通項目 =
    { 申請者: 従業員ID
    , 予定費用: 金額
    }

data 申請準備中 =
    { ...出張申請共通項目
    }

data 提出済み =
    { ...出張申請共通項目
    , 提出日時: String
    }

data 却下 = { 理由: String }

// 提出する: 予定費用が上限内なら提出済みへ遷移、超過なら却下
// 却下 はただの data。本線から外れるかは合成で決まる（14章）
behavior 提出する : (申請: 申請準備中, 提出日時: String) -> 提出済み | 却下
    constructs 提出済み, 却下

let 提出する (申請, 提出日時) = {
    require 申請.予定費用 <= 100000 else 却下 { 理由 = "high_cost" }
    提出済み { ...申請, 提出日時 = 提出日時 }
}

// behavior の隣に検査例を置く。コンパイル時に評価され、合わなければビルドが落ちる。
// 予定費用の閾値 100000 の両側で、提出済み / 却下 のどちらへ進むかを固定する。
example 提出する
    | "上限内なら提出できる" :
        (申請準備中 { 申請者 = 従業員ID("e-001"), 予定費用 = 金額(50000) }, "2026-07-20T09:00")
            -> 提出済み
    | "上限超過は却下" :
        (申請準備中 { 申請者 = 従業員ID("e-001"), 予定費用 = 金額(100001) }, "2026-07-20T09:00")
            -> 却下 { 理由 = "high_cost" }

// 組織図。社員は上司を持ち、上司もまた社員である ── data が自分自身を参照する。
// 連鎖の頂点（社長）には上司がいないので `上司: 社員?` で終端する。導出 decoder は
// この自己参照を辿って入れ子を読む。
data 社員 =
    { ID: 従業員ID
    , 上司: 社員?
    }

data 決裁レベル = Int

// 決裁レベル ＝ 申請者から最上位までの承認階層の深さ。上司の連鎖を根まで辿る再帰で、
// 深さが不定なので fold では書けない。再帰するヘルパーはメソッドへ lower され、自己呼び
// 出しはただのメソッド呼び出しになる（頂点で 0 に底を打つ）。戻り値の型は宣言する。
let 決裁の深さ (社員: 社員): Int =
    match 社員.上司 with
        | Some 上長 -> 決裁の深さ(上長) + 1
        | None -> 0

behavior 決裁レベルを測る : (社員: 社員) -> 決裁レベル
    constructs 決裁レベル

let 決裁レベルを測る (社員) = 決裁レベル(決裁の深さ(社員))

// === 多段承認：金額と申請者の決裁の深さで必要承認段数を決める ===
// 旧 expense 例（List<理由>・金額・多分岐）をこの申請モデルに吸収した。金額が大きいほど、また
// 理由が多いほど必要承認段数が上がり（多分岐）、申請者の決裁の深さ（上司連鎖の再帰）がそれに
// 満たなければ権限不足で止まる。承認済み段数が必要段数に達していれば完了、足りなければ追加承認。

data 理由 = { コード: String }

data 承認要求 =
    { 申請者: 社員
    , 金額: 金額
    , 理由リスト: List<理由>
    , 承認済み段数: Int
    }

data 承認完了
data 追加承認必要 = { 残り: Int }
data 決裁権限不足

// 必要承認段数：金額の閾値と理由の件数で1〜3段（多分岐）。List.length は理由の件数。
let 必要段数 (要求: 承認要求): Int =
    if 要求.金額.value >= 500000 || List.length(要求.理由リスト) >= 3 then 3
    else if 要求.金額.value >= 100000 || List.length(要求.理由リスト) >= 1 then 2
    else 1

// 承認判定：決裁の深さが必要段数に満たなければ権限不足。満たしていれば、承認済み段数が
// 必要段数に達しているかで 承認完了 / 追加承認必要 に分かれる。決裁の深さ は上司連鎖の再帰。
behavior 承認判定する : (要求: 承認要求) -> 承認完了 | 追加承認必要 | 決裁権限不足
    constructs 承認完了, 追加承認必要, 決裁権限不足

let 承認判定する (要求) = {
    require 決裁の深さ(要求.申請者) >= 必要段数(要求)
        else 決裁権限不足
    if 要求.承認済み段数 >= 必要段数(要求)
        then 承認完了
        else 追加承認必要 { 残り = 必要段数(要求) - 要求.承認済み段数 }
}

// 上司連鎖の深さ：boss を1人持てば深さ1、m→ceo と2人辿れば深さ2。連鎖の頂点は `上司 = None` で
// 終端する（fixture でも None を書ける。省略しても同じく None）。
example 承認判定する
    | "必要段数に達していれば承認完了" :
        (承認要求 { 申請者 = 社員 { ID = 従業員ID("e-1"), 上司 = 社員 { ID = 従業員ID("boss"), 上司 = None } }, 金額 = 金額(50000), 理由リスト = [], 承認済み段数 = 1 })
            -> 承認完了
    | "承認済みが足りなければ追加承認必要" :
        (承認要求 { 申請者 = 社員 { ID = 従業員ID("e-2"), 上司 = 社員 { ID = 従業員ID("m"), 上司 = 社員 { ID = 従業員ID("ceo"), 上司 = None } } }, 金額 = 金額(200000), 理由リスト = [], 承認済み段数 = 1 })
            -> 追加承認必要 { 残り = 1 }
    | "決裁の深さが必要段数に満たなければ権限不足" :
        (承認要求 { 申請者 = 社員 { ID = 従業員ID("e-1"), 上司 = 社員 { ID = 従業員ID("boss"), 上司 = None } }, 金額 = 金額(500000), 理由リスト = [], 承認済み段数 = 0 })
            -> 決裁権限不足
