module example.member
import String ( length, matches )
// exposing 句を省いたモジュールは生成クラスがすべて public になる（4章）。
// この例は全型を Java から使うので、あえて exposing を書かず全公開にしている。

// --- 値の型（単一プリミティブ newtype ＋ invariant）---
// 会員ID = 文字列 // 空文字列ではない
data 会員ID = String
    invariant length(value) > 0

// メールアドレス = 文字列 // ローカル部 @ ドメイン . TLD の書式（\\s / \\. は二重バックスラッシュ）
data メールアドレス = String
    invariant matches("[^@\\s]+@[^@\\s]+\\.[^@\\s]+", value)

// --- メールの確認状態 ---
// アドレスは「アクティベート済み」か「未アクティベート」のどちらか。通知はアクティベート済みにだけ
// 送れる——これを Bool フラグでなく直和で表し、通知 behavior の引数型を アクティベート済み にすることで
// 「未アクティベートには送れない」を型で強制する（不正な状態を表現できなくする）。
// 「状態を持つメールアドレスそのもの」なので、レコードで包まず メールアドレス を直接くるむ newtype にする。
data アクティベート済み = メールアドレス
data 未アクティベート = メールアドレス
data メール = アクティベート済み | 未アクティベート

// 表示など、状態を問わずアドレス値だけ要るとき用のヘルパ。
// newtype を入れ子で分解し、基底 String を一発で取り出す（.value.value を書かない）。
let アドレス値 (m: メール) =
    match m with
        | アクティベート済み(メールアドレス(s)) -> s
        | 未アクティベート(メールアドレス(s)) -> s

// --- 会員（直積）---
data 会員 =
    { id: 会員ID
    , メール: メール
    , 表示名: String
    }

// --- 照会の失敗ケース（ただの data。error でも Result でもない）---
data 会員なし
data 保存データ不正

// --- 外界依存：DB から会員を引く。jOOQ 実装を Java 側から注入する（13章）---
behavior findMember : (id: 会員ID) -> 会員 | 会員なし | 保存データ不正

// --- 表示用の整形（純粋 behavior）---
data 会員表示 =
    { id: String
    , メール: String
    , 表示名: String
    }

behavior 会員を表示用に整形する : (会員: 会員) -> 会員表示
    constructs 会員表示

let 会員を表示用に整形する (会員) = 会員表示 { id = 会員.id.value, メール = アドレス値(会員.メール), 表示名 = 会員.表示名 }

// --- 照会 → 整形 ---
behavior 会員を照会し整形する = findMember >-> 会員を表示用に整形する

// === 通知：アクティベート済みのメールにだけ送れる ===
// 送信そのものは注入 behavior（let 無し）。実装は Java 側のダミー（ログ出力）を注入する（13.2）。
// 宛先の型が アクティベート済み なので、未アクティベートのアドレスはそもそも渡せない。
// 送る1通のメール。宛先の型が アクティベート済み なので、未アクティベートのアドレスは組み立てられない。
data 通知 = { 宛先: アクティベート済み, 件名: String }
data 送信済み = { 宛先: メールアドレス }
data 未アクティベートのため送信不可

behavior 通知メールを送る : (通知: 通知) -> 送信済み
    constructs 送信済み

// 会員へ通知する：メール状態を match し、アクティベート済みなら送る（通知メールを送る を requires）、
// 未アクティベートなら型どおり送信不可を返す。
behavior 会員へ通知する : (会員: 会員, 件名: String) -> 送信済み | 未アクティベートのため送信不可
    requires 通知メールを送る

let 会員へ通知する (会員, 件名, 通知メールを送る) =
    match 会員.メール with
        | アクティベート済み as 宛先 -> 通知メールを送る(通知 { 宛先 = 宛先, 件名 = 件名 })
        | 未アクティベート -> 未アクティベートのため送信不可

fake 通知メールを送る
    | _ -> 送信済み { 宛先 = メールアドレス("a@example.com") }

example 会員へ通知する
    | "アクティベート済みには通知が送れる" :
        (会員 { id = 会員ID("m-1"), メール = アクティベート済み(メールアドレス("a@example.com")), 表示名 = "A" }, "お知らせ")
            -> 送信済み { 宛先 = メールアドレス("a@example.com") }
    | "未アクティベートには送れない" :
        (会員 { id = 会員ID("m-2"), メール = 未アクティベート(メールアドレス("b@example.com")), 表示名 = "B" }, "お知らせ")
            -> 未アクティベートのため送信不可

// === 会員登録：DB の状態（メール重複）を読んでから登録する ===
data 登録要求 =
    { メール: メールアドレス
    , 表示名: String
    }

data 登録済み = { id: 会員ID }
data 重複メール

// --- 外界依存（Java 注入）---
behavior findByEmail : (メール: メールアドレス) -> 会員 | 会員なし
behavior 発番する : (要求: 登録要求) -> 会員ID
    constructs 会員ID
behavior saveMember : (会員: 会員) -> 登録済み
    constructs 登録済み

// --- 登録：読む → 検査 → 書く ---
// 新規会員のメールは未アクティベート（登録直後は確認前）。
behavior 登録する : (要求: 登録要求) -> 登録済み | 重複メール
    requires findByEmail, 発番する, saveMember

let 登録する (要求, findByEmail, 発番する, saveMember) =
    match findByEmail(要求.メール) with
        | 会員 as _ -> 重複メール
        | 会員なし   -> saveMember(会員 {
            id = 発番する(要求),
            メール = 未アクティベート(要求.メール),
            表示名 = 要求.表示名
        })

// --- fake + example ---
fake findByEmail
    | (メールアドレス("dup@example.com")) -> 会員 { id = 会員ID("m-1"), メール = 未アクティベート(メールアドレス("dup@example.com")), 表示名 = "既存" }
    | _ -> 会員なし

fake 発番する
    | _ -> 会員ID("m-100")

fake saveMember
    | _ -> 登録済み { id = 会員ID("m-100") }

example 登録する
    | "新規メールは登録できる" :
        (登録要求 { メール = メールアドレス("new@example.com"), 表示名 = "新人" })
            -> 登録済み { id = 会員ID("m-100") }
    | "既存メールは重複で止まる" :
        (登録要求 { メール = メールアドレス("dup@example.com"), 表示名 = "重複" })
            -> 重複メール
