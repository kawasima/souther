// List<T> ／ size ／ 算術 ／ 多分岐成功。decoder/encoder は導出される。
module example.expense

data 理由 = { コード: String }

data 申請 = {
    予定費用: Int
    理由リスト: List<理由>
}

data 通常 = { 件数: Int }
data 要審査 = { 件数: Int }

// 理由が1件以上、または高額なら要審査へ。そうでなければ通常。
behavior 区分する : (a: 申請) -> 通常 | 要審査
    constructs 通常, 要審査

let 区分する (a) =
    if length(a.理由リスト) >= 1 || a.予定費用 >= 100000
        then 要審査 { 件数: length(a.理由リスト) }
        else 通常 { 件数: length(a.理由リスト) }
