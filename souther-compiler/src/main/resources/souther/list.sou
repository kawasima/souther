module souther.list

// The list combinators (ADR-0028), derived from the one privileged loop primitive `List.fold`. Each
// is a helper expanded inline at its call site, where the type variables resolve to the concrete
// argument types — no polymorphic method is emitted. `map`/`filter` seed the empty list `[]` and
// grow it as the block runs; `all`/`any` fold a `Bool`. Passing a lambda to the `f`/`p` parameter is
// fine: it is β-reduced inside the fold, so `List.map(x -> ..., xs)` reads as a loop would.
//
// Argument order follows F#/Elm (spec §pipe): the function or predicate comes first and the list —
// the value being transformed — comes last, so `xs |> List.map(f) |> List.filter(p)` reads top to
// bottom. `List.fold(step, seed, xs)` likewise takes the list last; its step keeps `(acc, x)`.
//
// Names are qualified (`List.fold`, `List.length`): the standard library carries no bare names — you
// reach it through `List.`/`String.`/`Map.`/`Bool.` (spec §stdlib). `++` and `==` are operators, so
// they stay bare, and `f(x)` calls a parameter, not the library.
// `foldFrom` is an ordinary recursive helper, not a privileged loop: it walks the list by index and
// threads the accumulator, exactly as fold is written in Elm or F#. The step is a first-class function
// value (a closure), applied per element; the self-call is in tail position, so the backend turns the
// recursion into a loop (no per-element stack frame). `List.get` gives the base case: `None` past the
// end of the list yields the seed. Every combinator below is derived from it.
let foldFrom (step: ('acc, 'a) -> 'acc, seed: 'acc, xs: List<'a>, i: Int) : 'acc =
    match List.get(i, xs) with
        | Some x -> List.foldFrom(step, step(seed, x), xs, i + 1)
        | None -> seed

let map (f: ('a) -> 'b, xs: List<'a>) = List.fold((acc, x) -> acc ++ [f(x)], [], xs)
let filter (keep: ('a) -> Bool, xs: List<'a>) = List.fold((acc, x) -> if keep(x) then acc ++ [x] else acc, [], xs)
let all (p: ('a) -> Bool, xs: List<'a>) = List.fold((acc, x) -> acc && p(x), true, xs)
let any (p: ('a) -> Bool, xs: List<'a>) = List.fold((acc, x) -> acc || p(x), false, xs)

// More of Elm's List module. `sum`/`product` fold a number; `concat` folds with `++`; `member`
// folds a Bool using `==` (so it works over any comparable element); `isEmpty` reads the length.
// `List.concat` and `String.concat` are distinct now that names are qualified.
//
// `reverse` is a native primitive, not a fold: a left fold can only build a reversed list by
// prepending (`[x] ++ acc`), and a prepend copies the whole accumulator on an array-backed list, so
// the fold form is O(n²). The intrinsic walks the input from the end in O(n) (like `sort`).
let reverse (xs: List<'a>) : List<'a> = intrinsic "list.reverse"
let sum (xs: List<Int>) = List.fold((acc, x) -> acc + x, 0, xs)
let product (xs: List<Int>) = List.fold((acc, x) -> acc * x, 1, xs)
let concat (xss: List<List<'a>>) = List.fold((acc, xs) -> acc ++ xs, [], xss)
let member (e: 'a, xs: List<'a>) = List.fold((acc, x) -> acc || x == e, false, xs)
let isEmpty (xs: List<'a>) = List.length(xs) == 0

// `distinct` keeps the first occurrence of each element and drops later duplicates, comparing by
// value equality (Elm's List.Extra `unique`). It folds a pair of a `Set` of the elements seen so far
// and the result list: an element already in the set is skipped, otherwise it joins both. Consulting
// a `Set` (O(log n)) rather than scanning the growing list with `member` (O(n)) is what keeps it
// O(n log n); the result list keeps first-seen order. The seen-set is discarded at the end. This is
// the same shape as `groupBy`, which grows a `Map` accumulator from within `List.fold`.
//
// The seen-set is inserted into on every element, including duplicates (a duplicate insert is a
// no-op that returns the same set). That is deliberate: only the list side is conditional. If the
// whole step were `if seen then acc else (insert, ys ++ [x])`, the skip branch would return the bare
// empty-seeded accumulator, whose element types are still the `[]`/`Set.empty` bottoms, and the two
// `if` branches would disagree with the concrete else branch. Keeping the tuple's shape the same in
// both branches (the set always grows, only the list is guarded) keeps both sides concretely typed.
let distinct (xs: List<'a>) = {
    let (_, out) = List.fold((acc, x) -> {
        let (seen, ys) = acc
        let nextYs = if Set.contains(x, seen) then ys else ys ++ [x]
        (Set.insert(x, seen), nextYs)
    }, (Set.empty(), []), xs)
    out
}

// `partition` splits the list by a predicate into (kept, rest), preserving order in each (Elm's
// List.partition). It folds a pair of empty lists `([], [])`, appending each element to one side —
// the accumulator's real shape is the pair of lists the block grows, not the bottoms the seed holds.
let partition (keep: ('a) -> Bool, xs: List<'a>) =
    List.fold((acc, x) -> {
        let (yes, no) = acc
        if keep(x) then (yes ++ [x], no) else (yes, no ++ [x])
    }, ([], []), xs)

// `groupBy` buckets the elements by a key into a `Map<'k, List<'a>>`, each bucket in first-seen
// order (Elm's Dict-based grouping). It folds `Map.empty`, reading the current bucket with `Map.get`
// (a `None` starts a new one) and writing back the extended bucket — a Map accumulator grown the same
// way `distinct` grows a list, its key and value types recovered from the block.
let groupBy (key: ('a) -> 'k, xs: List<'a>) =
    List.fold((acc, x) ->
        Map.insert(key(x),
            match Map.get(key(x), acc) with
                | None -> [x]
                | Some bucket -> bucket ++ [x],
            acc),
        Map.empty(), xs)

// `sort` orders by the elements' natural order (Elm `List.sort`). Like Elm it is a native
// primitive, not a fold: an in-language sort needs comparison plus a place to remember the
// half-built result, which `fold` alone does not give.
let sort (xs: List<'a>) : List<'a> = intrinsic "list.sort"
